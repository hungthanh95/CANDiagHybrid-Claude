<?xml version="1.0" encoding="utf-8"?>
<systemvariables version="4">
  <namespace name="Diag" comment="FlexDiag Option B request/response sysvars (docs/03 TECHNICAL-DETAIL.md sec 2)" interface="">
    <variable name="ReqData" type="data" arrayLength="4095" comment="Raw request bytes (full UDS frame). Byte array, size >= 4095 (kMaxLen)." readOnly="false" valueSequence="false" unit="" bitcount="0" isSigned="false" encoding="65001" anlyzLocal="2" />
    <variable name="ReqSeq" type="int" comment="Correlation id; written before ReqTrigger." readOnly="false" valueSequence="false" unit="" bitcount="32" isSigned="true" encoding="65001" startValue="0" anlyzLocal="2" />
    <variable name="ReqKind" type="int" comment="0=RAW, 1=READDTC, 2=CLEARDTC, 3=SECURITY, 4=SESSION, 5=TP_START, 6=TP_STOP." readOnly="false" valueSequence="false" unit="" bitcount="32" isSigned="true" encoding="65001" startValue="0" anlyzLocal="2" />
    <variable name="ReqArg" type="int" comment="Generic arg (e.g. security level, session id, mask)." readOnly="false" valueSequence="false" unit="" bitcount="32" isSigned="true" encoding="65001" startValue="0" anlyzLocal="2" />
    <variable name="ReqTrigger" type="int" comment="Incremented by the bridge to fire the request; CAPL reacts on change." readOnly="false" valueSequence="false" unit="" bitcount="32" isSigned="true" encoding="65001" startValue="0" anlyzLocal="2" />
    <variable name="RspData" type="data" arrayLength="4095" comment="Raw response bytes (positive or 7F..). Byte array, size >= 4095 (kMaxLen)." readOnly="false" valueSequence="false" unit="" bitcount="0" isSigned="false" encoding="65001" anlyzLocal="2" />
    <variable name="RspSeq" type="int" comment="Echoed correlation id (mirrors ReqSeq)." readOnly="false" valueSequence="false" unit="" bitcount="32" isSigned="true" encoding="65001" startValue="0" anlyzLocal="2" />
    <variable name="RspStatus" type="int" comment="0=positive UDS response, 1=negative response/NRC, 2=OK (non-UDS), 3=ERR keygen_fail, 4=ERR ecu_timeout." readOnly="false" valueSequence="false" unit="" bitcount="32" isSigned="true" encoding="65001" startValue="0" anlyzLocal="2" />
    <variable name="RspKind" type="int" comment="Echoes ReqKind (same 0-6 enum) for the operation this response belongs to." readOnly="false" valueSequence="false" unit="" bitcount="32" isSigned="true" encoding="65001" startValue="0" anlyzLocal="2" />
    <variable name="RspTrigger" type="int" comment="Incremented by CAPL when a response is ready; the bridge reacts on change." readOnly="false" valueSequence="false" unit="" bitcount="32" isSigned="true" encoding="65001" startValue="0" anlyzLocal="2" />
  </namespace>
</systemvariables>
